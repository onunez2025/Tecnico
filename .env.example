# ============================================================
# VARIABLES DE ENTORNO - Tecnico / Gestión Técnica de Servicios
# Copiar este archivo como .env y completar los valores reales.
# NUNCA commitear el archivo .env al repositorio.
# ============================================================

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development
# En production usar el dominio real, ej: https://app.mti.com.pe
ALLOWED_ORIGIN=http://localhost:3000

# --- JWT ---
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# --- BASE DE DATOS AZURE SQL ---
DB_SERVER=tu-servidor.database.windows.net
DB_DATABASE=nombre_base_de_datos
DB_USER=usuario_sql
DB_PASSWORD=contraseña_sql

# --- AZURE BLOB STORAGE ---
# Obtener desde: Azure Portal > Storage Account > Access keys > Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=stecnico

# --- RUTAS LOCALES (solo si se usan montajes locales) ---
# Ruta al directorio donde AppSheet almacena los PDFs de cotizaciones.
# Dejar vacío si no se usa esta función.
APPSHEET_PDF_PATH=

# Ruta al directorio de imágenes estáticas (OneDrive mount / R2 mount).
# Dejar vacío si no se usa esta función.
IMAGE_STORAGE_PATH=
